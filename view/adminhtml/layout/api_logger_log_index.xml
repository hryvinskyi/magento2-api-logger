<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <update handle="api_logger_menu"/>
    <head>
        <css src="Hryvinskyi_ApiLogger::css/log-grid.css"/>
    </head>
    <body>
        <referenceBlock name="hryvinskyi.api.logger.menu">
            <arguments>
                <argument name="menu_title" xsi:type="string" translate="true">API Logger: Logs</argument>
                <argument name="items" xsi:type="array">
                    <item name="logs" xsi:type="array">
                        <item name="class" xsi:type="array">
                            <item name="current" xsi:type="boolean">true</item>
                        </item>
                    </item>
                </argument>
            </arguments>
        </referenceBlock>
        <referenceContainer name="content">
            <uiComponent name="api_logger_log_listing"/>
        </referenceContainer>
    </body>
</page>
